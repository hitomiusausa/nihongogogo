# Optional local settings for scripts/run_daily.sh.
# Copy this file to config/local.env and edit the values. config/local.env is ignored by git.

# Number of recent days to include in daily reports.
SINCE_DAYS=14

# Optional shared folder. Examples:
# NIHONGO_WATCH_PUBLIC_DIR="$HOME/Library/CloudStorage/GoogleDrive-USER@example.com/My Drive/Nihongo Watch"
# NIHONGO_WATCH_PUBLIC_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Nihongo Watch"
# NIHONGO_WATCH_PUBLIC_DIR="$HOME/Dropbox/Nihongo Watch"
NIHONGO_WATCH_PUBLIC_DIR=""

